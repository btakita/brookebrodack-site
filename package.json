{
	"name": "@btakita/brookebrodack-site",
	"module": "index.ts",
	"type": "module",
	"exports": {
		".": "./index.ts",
		"./jsonld/index.js": "./jsonld/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "bun build.ts",
		"clear": "rm -rf ./dist",
		"dev": "bun run dev:sourcemap__resolve__bun",
		"dev:raw": "bun index.ts",
		"dev:sourcemap__resolve__bun": "sourcemap__resolve__bun -f index.ts",
		"db:drop": "drizzle-kit drop",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "bun ./db/migrate.ts",
		"db:push": "drizzle-kit push",
		"start": "sourcemap__resolve__bun -f start.ts",
		"clean": "rm -rf ./dist"
	},
	"dependencies": {
		"@btakita/domain--any--brookebrodack": "workspace:*",
		"@btakita/domain--server--brookebrodack": "workspace:*",
		"@btakita/ui--any--brookebrodack": "workspace:*",
		"@btakita/ui--browser--brookebrodack": "workspace:*",
		"@btakita/ui--server--brookebrodack": "workspace:*",
		"@rappstack/domain--any--blog": "^0.1.0",
		"@rappstack/domain--server": "^0.1.0",
		"@rappstack/domain--server--auth": "^0.1.0",
		"@rappstack/domain--server--blog": "^0.1.0",
		"@rappstack/ui--any": "^0.1.0",
		"@rappstack/ui--any--blog": "^0.1.0",
		"@rappstack/ui--server": "^0.1.0",
		"@rappstack/ui--server--blog": "^0.1.0",
		"@sinclair/typebox": "^0.34.48",
		"cssnano": "^7.1.3",
		"ctx-core": "^7.2.33",
		"drizzle-kit": "^0.31.9",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.0.0",
		"esbuild-plugin-esmfile": "^0.2.11",
		"esbuild-plugin-object-store-asset": "0.0.3",
		"esmcss": "^0.2.14",
		"marked": "^17.0.4",
		"object-store-asset": "^0.0.1",
		"relementjs": "^0.80.32",
		"rhonojs": "^0.1.2",
		"tailwindcss-noscript": "^2.0.1"
	},
	"devDependencies": {
		"@btakita/dev-bin": "^0.1.0",
		"@ctx-core/preprocess": "^0.2.3",
		"@rebuildjs/tailwindcss": "^0.11.1",
		"better-sqlite3": "^12.6.2",
		"bun-types": "latest",
		"esbuild-style-plugin": "^1.6.3",
		"postcss": "^8.5.8",
		"schema-dts": "^1.1.5",
		"tailwindcss": "^4.2.1"
	},
	"peerDependencies": {
		"typescript": "^5.5.3"
	}
}
